# Este archivo NO se commitea: copia a `.env.e2e` y rellena valores.
# Playwright y `tests/e2e/utils/preflight.ts` cargan `.env.e2e` automáticamente si existe.
# Guía: docs/E2E_INTEGRATION.md

## Base URL e2e (opcional; por defecto Playwright usa 127.0.0.1:3005)
E2E_BASE_URL="http://127.0.0.1:3005"
E2E_PORT="3005"

## API keys por rol (obligatorio para e2e full)
E2E_API_KEY=""
E2E_ADMIN_API_KEY=""
E2E_USER_API_KEY=""
E2E_TECHLEAD_API_KEY=""

## IDs de proyecto para pruebas de negocio (obligatorio para e2e full)
E2E_DAILY_PROJECT_ID=""
E2E_NON_MEMBER_PROJECT_ID=""
E2E_AI_PROJECT_ID=""

## Email objetivo para --as-user (obligatorio para e2e full)
E2E_AS_USER_EMAIL=""

## Sesión autenticada para pruebas web dashboard
## Genera este archivo con Playwright o exportando storage state desde una sesión Clerk QA.
E2E_STORAGE_STATE=".auth/qa-admin-storage-state.json"

## Overrides del CLI (usados por tests CLI)
ASYNCREPORT_BASE_URL=""
ASYNCREPORT_API_KEY=""
