#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if [[ "${SKIP_LOCAL_GATES:-0}" == "1" ]]; then
  echo "SKIP_LOCAL_GATES=1 detectado: se omiten quality gates locales."
  exit 0
fi

echo "Ejecutando quality gates locales antes de push..."
npm run local:prepush
