{
  "name": "asyncreport",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:cli": "vitest run __tests__/cli",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "cli": "tsx cli/index.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:full": "tsx tests/e2e/utils/preflight.ts && PW_RUN_WEB_E2E=1 playwright test",
    "test:e2e:quick": "PW_RUN_WEB_E2E=1 playwright test tests/e2e/api tests/e2e/web/public-routes.spec.ts",
    "test:integration": "npm test && npm run test:e2e:full",
    "security:supabase": "node scripts/check-supabase-security.mjs",
    "security:deps:audit": "npm audit --omit=dev",
    "security:deps:report": "node scripts/dependency-audit-report.mjs"
  },
  "prisma": {
    "seed": "npm run prisma:seed"
  },
  "dependencies": {
    "@clerk/nextjs": "latest",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "latest",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "chalk": "^5.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "framer-motion": "^12.34.1",
    "inquirer": "^13.4.2",
    "lucide-react": "^0.574.0",
    "next": "latest",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "latest",
    "react-dom": "latest",
    "react-hook-form": "^7.73.1",
    "resend": "^6.12.2",
    "sonner": "^2.0.7",
    "svix": "^1.90.0",
    "tailwind-merge": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.2.3",
    "@types/pg": "^8.20.0",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.4.19",
    "dotenv": "^17.4.2",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "happy-dom": "^20.9.0",
    "postcss": "^8.4.38",
    "prisma": "latest",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "latest",
    "vitest": "^4.1.4"
  }
}
